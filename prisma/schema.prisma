// Serveup - Super Admin Panel
// Database schema for restaurant ordering system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String?  @unique
  username     String?  @unique
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())

  @@map("admin_users")
}

model AllowedIP {
  id        Int      @id @default(autoincrement())
  ipAddress String   @unique
  label     String?
  createdAt DateTime @default(now())

  @@map("allowed_ips")
}

model LoginLog {
  id        Int      @id @default(autoincrement())
  ipAddress String
  success   Boolean
  timestamp DateTime @default(now())

  @@map("login_logs")
}

model Restaurant {
  id            Int      @id @default(autoincrement())
  uuid          String   @unique @default(uuid())
  name          String
  slug          String   @unique
  ownerName     String
  ownerEmail    String
  ownerPhone    String
  logoUrl       String?
  bannerUrl     String?
  backgroundUrl String?
  frameUrl      String?
  frameVariants String?
  primaryColor       String   @default("#c2410c")
  categoryTextColor  String?  // צבע טקסט קטגוריות (שמות קטגוריות בתפריט)
  categoryBubbleSecondaryColor String?  // צבע בועות קטגוריות ללא פוקוס (משני)
  secondaryColor     String?  // כותרות קטגוריות
  textColor          String?  // טקסט מנות
  descriptionColor   String?  // תיאור
  priceColor         String?  // מחיר
  cartColor          String?  // צבע כפתור עגלה (הוסף לעגלה)
  cartTextColor      String?  // צבע טקסט בעגלה (כפתור הוסף לעגלה)
  cartBackgroundUrl     String?  // רקע אזור עגלה (תמונה via URL)
  cartBarOverlayOpacity   Int?     // אטימות שכבת הכהות על רקע עגלה (0–100), ברירת מחדל 45
  cartBarControlsOpacity Int?     // נראות כפתור הוסף לעגלה ו+/- (0–100, 100=אטום)
  expansionBackdropOpacity Int?   // אטימות השחרת רקע מודאל ההרחבה (0–100, ברירת מחדל 70)
  flyingDiscVisibility    Int?    // נראות דיסקית הוספה לעגלה (0=מוסתר, 100=מוצג)
  bottomNavColor        String?  // צבע מילוי עיגולים בתחתית (מסגרת שחורה קבועה)
  bottomNavIconColor String?  // צבע אייקונים בעיגולים בתחתית
  summaryCardColor    String?  // צבע כרטיסי פריטים בדף סיכום הזמנה
  summaryTabPrimaryColor   String?  // לחיצה ראשי סיכום הזמנה – צבע כפתור פעיל (סל שלי)
  summaryTabSecondaryColor String?  // לחיצה משני סיכום הזמנה – צבע כפתור פעיל (הוזמן)
  summarySubmitButtonColor String?  // צבע כפתור "הזמן" (שליחת ההזמנה) – בסגנון וולט
  menuDisplayFormat  String   @default("large") // large | compact
  textSize           Int      @default(16)      // גודל טקסט בסיס (px)
  fontFamily         String?  // פונט (למשל Heebo, Assistant)
  city               String
  openTime          String?  // שעות פתיחה ישראל HH:mm (למשל 09:00)
  closeTime         String?  // שעות סגירה ישראל HH:mm (למשל 18:00)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  whatsappPhoneNumberId String?  // מזהה המספר ב-WhatsApp Cloud API – לקישור בוט למסעדה
  receptionDontNotifyReady Boolean @default(false)  // מסך קבלה: אל תודיע מוכן, תמחק אחרי X דקות
  receptionAutoDeleteMinutes Int?  // מסך קבלה: מחק הזמנות אוטומטית אחרי דקות (למשל 30) כש־receptionDontNotifyReady
  receptionAlertAfterMinutes Int?  // מסך קבלה: התראת זמן – שולחן וכרטיסיה אדומים + צליל אחרי X דקות

  tables        Table[]
  categories    Category[]
  orderSessions OrderSession[]

  @@map("restaurants")
}

model Category {
  id           Int      @id @default(autoincrement())
  restaurantId Int
  name         String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dishes     Dish[]

  @@map("categories")
}

model Dish {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  title       String
  imageUrl    String?
  description String?
  allergens   String?
  priceCents  Int      @default(0)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  category            Category               @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  paramCategories    DishParameterCategory[]
  cartItems          CartItem[]
  submissionItems    OrderSubmissionItem[]

  @@map("dishes")
}

model DishParameterCategory {
  id           Int    @id @default(autoincrement())
  dishId       Int
  name         String   // למשל "בחרו לחם"
  sortOrder    Int      @default(0)
  minSelections Int     @default(0)
  maxSelections Int     @default(1)

  dish       Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)
  parameters DishParameter[]

  @@map("dish_parameter_categories")
}

model DishParameter {
  id         Int    @id @default(autoincrement())
  categoryId Int
  name       String   // למשל "פיתה", "באגט"
  sortOrder  Int      @default(0)
  priceCents Int      @default(0)   // תוספת מחיר (אופציונלי)

  category DishParameterCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("dish_parameters")
}

model Table {
  id           Int      @id @default(autoincrement())
  restaurantId Int
  tableNumber  Int
  label        String?  // שם להצגה (ניתן לעריכה): "1", "2", "A"
  description  String?
  token        String   @unique
  capacity     Int      @default(2)   // כמות מקומות
  positionX    Float?   // מיקום על המפה (0-100)
  positionY    Float?
  shape        String?  // "circle" | "rectangle"
  isOffline    Boolean  @default(false)  // שולחן מכובה – הלינק לא עובד, השולחן לא נמחק
  createdAt    DateTime @default(now())

  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderSessions OrderSession[]

  @@map("tables")
}

// סשן הזמנה (טרמינל) – לקוח שפתח לינק, עגלה נשמרת עד תום זמן או סיום הזמנה
model OrderSession {
  id           Int       @id @default(autoincrement())
  restaurantId Int
  tableId      Int?      // אופציונלי – שולחן מקושר (מהמפה)
  token        String    @unique // מזהה ב-URL – פתיחת הלינק עם הטוקן מחזירה את אותו סשן
  label        String?   // תווית להצגה (למשל "שולחן 3" או "טרמינל 1")
  status       String    @default("active") // active | closed | expired
  createdAt    DateTime  @default(now())
  expiresAt    DateTime  // תום תוקף (למשל 90 דקות מהפתיחה)

  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table        Table?           @relation(fields: [tableId], references: [id], onDelete: SetNull)
  cartItems    CartItem[]
  submissions  OrderSubmission[]

  @@map("order_sessions")
}

// פריט בעגלה של סשן – משויך לאורח (מכשיר) לפי guestId
model CartItem {
  id             Int     @id @default(autoincrement())
  orderSessionId Int
  guestId        String? // מזהה אורח (מכשיר) – כל מכשיר סל משלו (null = פריטים ישנים)
  dishId         Int
  quantity       Int     @default(1)
  priceCents     Int      // מחיר נשמר בזמן ההוספה
  selections     Json?    // בחירות פרמטרים: [{ paramCategoryId, parameterId }] או מערך דומה

  orderSession OrderSession @relation(fields: [orderSessionId], references: [id], onDelete: Cascade)
  dish         Dish         @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@map("cart_items")
}

// הזמנה שנשלחה (הוזמן) – פריטים שעברו מ"סל שלי" לשליחה
model OrderSubmission {
  id             Int      @id @default(autoincrement())
  orderSessionId Int
  guestId        String
  submittedAt    DateTime @default(now())
  status         String   @default("pending") // pending | ready – למסך הקבלה (הודיע מוכן)

  orderSession OrderSession        @relation(fields: [orderSessionId], references: [id], onDelete: Cascade)
  items        OrderSubmissionItem[]

  @@map("order_submissions")
}

model OrderSubmissionItem {
  id               Int    @id @default(autoincrement())
  orderSubmissionId Int
  dishId           Int
  quantity         Int    @default(1)
  priceCents       Int
  selections       Json?

  orderSubmission OrderSubmission @relation(fields: [orderSubmissionId], references: [id], onDelete: Cascade)
  dish            Dish            @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@map("order_submission_items")
}
