// Serveup - Super Admin Panel
// Database schema for restaurant ordering system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String?  @unique
  username     String?  @unique
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())

  @@map("admin_users")
}

model AllowedIP {
  id        Int      @id @default(autoincrement())
  ipAddress String   @unique
  label     String?
  createdAt DateTime @default(now())

  @@map("allowed_ips")
}

model LoginLog {
  id        Int      @id @default(autoincrement())
  ipAddress String
  success   Boolean
  timestamp DateTime @default(now())

  @@map("login_logs")
}

model Restaurant {
  id            Int      @id @default(autoincrement())
  uuid          String   @unique @default(uuid())
  name          String
  slug          String   @unique
  ownerName     String
  ownerEmail    String
  ownerPhone    String
  logoUrl       String?
  bannerUrl     String?
  backgroundUrl String?
  frameUrl      String?
  frameVariants String?
  primaryColor       String   @default("#c2410c")
  categoryTextColor  String?  // צבע טקסט קטגוריות (שמות קטגוריות בתפריט)
  secondaryColor     String?  // כותרות קטגוריות
  textColor          String?  // טקסט מנות
  descriptionColor   String?  // תיאור
  priceColor         String?  // מחיר
  cartColor          String?  // צבע כפתור עגלה (הוסף לעגלה)
  cartTextColor      String?  // צבע טקסט בעגלה (כפתור הוסף לעגלה)
  cartBackgroundUrl     String?  // רקע אזור עגלה (תמונה via URL)
  cartBarOverlayOpacity   Int?     // אטימות שכבת הכהות על רקע עגלה (0–100), ברירת מחדל 45
  cartBarControlsOpacity Int?     // נראות כפתור הוסף לעגלה ו+/- (0–100, 100=אטום)
  expansionBackdropOpacity Int?   // אטימות השחרת רקע מודאל ההרחבה (0–100, ברירת מחדל 70)
  bottomNavColor        String?  // צבע מילוי עיגולים בתחתית (מסגרת שחורה קבועה)
  bottomNavIconColor String?  // צבע אייקונים בעיגולים בתחתית
  menuDisplayFormat  String   @default("large") // large | compact
  textSize           Int      @default(16)      // גודל טקסט בסיס (px)
  fontFamily         String?  // פונט (למשל Heebo, Assistant)
  city               String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  whatsappPhoneNumberId String?  // מזהה המספר ב-WhatsApp Cloud API – לקישור בוט למסעדה

  tables     Table[]
  categories Category[]

  @@map("restaurants")
}

model Category {
  id           Int      @id @default(autoincrement())
  restaurantId Int
  name         String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dishes     Dish[]

  @@map("categories")
}

model Dish {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  title       String
  imageUrl    String?
  description String?
  allergens   String?
  priceCents  Int      @default(0)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  paramCategories DishParameterCategory[]

  @@map("dishes")
}

model DishParameterCategory {
  id           Int    @id @default(autoincrement())
  dishId       Int
  name         String   // למשל "בחרו לחם"
  sortOrder    Int      @default(0)
  minSelections Int     @default(0)
  maxSelections Int     @default(1)

  dish       Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)
  parameters DishParameter[]

  @@map("dish_parameter_categories")
}

model DishParameter {
  id         Int    @id @default(autoincrement())
  categoryId Int
  name       String   // למשל "פיתה", "באגט"
  sortOrder  Int      @default(0)
  priceCents Int      @default(0)   // תוספת מחיר (אופציונלי)

  category DishParameterCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("dish_parameters")
}

model Table {
  id           Int      @id @default(autoincrement())
  restaurantId Int
  tableNumber  Int
  label        String?  // שם להצגה (ניתן לעריכה): "1", "2", "A"
  description  String?
  token        String   @unique
  capacity     Int      @default(2)   // כמות מקומות
  positionX    Float?   // מיקום על המפה (0-100)
  positionY    Float?
  shape        String?  // "circle" | "rectangle"
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("tables")
}
